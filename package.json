{
  "name": "fsim",
  "version": "0.1.5",
  "description": "Combat flight simulator — US vs Russian fighters",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src",
    "test": "vitest run",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false",
    "dist:mac": "electron-builder --mac dmg zip --arm64 --x64 --publish never"
  },
  "dependencies": {
    "three": "^0.165.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@types/three": "^0.165.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "electron": "^42.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.fsim.app",
    "productName": "FSim",
    "asar": true,
    "asarUnpack": [
      "dist-electron/renderer/sounds/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.games",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "FSim ${version}"
    }
  }
}
