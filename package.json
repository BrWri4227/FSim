{
  "name": "fsim",
  "version": "0.1.4",
  "description": "Combat flight simulator — US vs Russian fighters",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "three": "^0.165.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@types/three": "^0.165.0",
    "electron": "^42.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.fsim.app",
    "productName": "FSim",
    "asar": true,
    "asarUnpack": [
      "dist-electron/renderer/sounds/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**"
    ]
  }
}
